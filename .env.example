# GEMINI_AI (Google AI Studio)
# AI Studio automatically injects this at runtime from user secrets.
# For Vercel: Create a secret named GEMINI_API_KEY with your Google AI API Key.
GEMINI_API_KEY=

# APP_URL: The base URL of the application.
# In AI Studio, this is automatically set to the Cloud Run URL.
# For Vercel: Set this to your deployment URL (e.g., https://your-app.vercel.app).
# You can often use VERCEL_URL on the server, but for client-side transparency, 
# explicit APP_URL is recommended.
APP_URL=

# Supabase Configuration
# Required for database and authentication integration.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Vercel Supabase Integration variables (sometimes without VITE_ prefix for server-side)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago Configuration
# Required for processing payments.
MERCADO_PAGO_ACCESS_TOKEN=
VITE_MERCADO_PAGO_PUBLIC_KEY=

# VERCEL SYSTEM VARIABLES (Provided by Vercel)
# VERCEL_URL - The URL of the deployment
# VERCEL_ENV - The environment (production, preview, or development)
